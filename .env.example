# Brutus Railway/local server env example. Do not put real secrets in git.
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Railway: use a mounted volume for SQLite, for example /data/brutus.db.
# Without a volume, SQLite data is ephemeral on redeploy.
DATABASE_URL=file:/data/brutus.db

# Set to your Railway domain after deploy, e.g. https://brutus-production.up.railway.app
# For same-origin frontend served by Express, this is mainly needed for explicit CORS allowlist.
CLIENT_ORIGIN=https://your-railway-domain.up.railway.app

# Generate with: openssl rand -base64 32
JWT_SECRET=replace-me-with-openssl-rand-base64-32

LOG_LEVEL=info
WALLET_AUTH_ENABLED=false
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
BRUTUS_COMBAT_REWARDS=0x79182dEF2B8662F2F932B358bbd0F4Ab6496fe8F

# Server operator key for recording combat rewards. Set in Railway variables only.
# BRUTUS_OPERATOR_PRIVATE_KEY=0x...
