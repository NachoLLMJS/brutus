{
  "name": "server",
  "version": "0.3.0",
  "private": true,
  "description": "Brutus backend: Express + Prisma + SQLite. Persists brutes, runs deterministic combat server-side, exposes REST API.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "npm run build -w core && npm run prisma:generate && tsc -p tsconfig.json",
    "railway:build": "npm run build",
    "start": "prisma migrate deploy --schema=../prisma/schema.prisma && node dist/index.js",
    "start:railway": "npm run start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=../prisma/schema.prisma",
    "prisma:seed": "tsx ../prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "core": "*",
    "cors": "2.8.5",
    "express": "4.22.1",
    "express-rate-limit": "7.4.1",
    "helmet": "8.0.0",
    "nanoid": "5.1.9",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "prisma": "5.22.0",
    "viem": "^2.53.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "22.7.4",
    "tsx": "4.21.0",
    "typescript": "5.6.3"
  }
}
