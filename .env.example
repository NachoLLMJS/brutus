# Server
PORT=3001
HOST=127.0.0.1
NODE_ENV=development

# Database (SQLite local; cambiar a postgresql:// para producción)
DATABASE_URL="file:./dev.db"

# Frontend → Backend
CLIENT_ORIGIN=http://localhost:5173

# Web3 (placeholders, sin uso aún)
JWT_SECRET=replace-me-with-openssl-rand-base64-32
WALLET_AUTH_ENABLED=false
