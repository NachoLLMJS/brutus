# Server
PORT=3001
# Local dev: 127.0.0.1. Railway/production: 0.0.0.0
HOST=127.0.0.1
NODE_ENV=development

# Database
# Local SQLite:
DATABASE_URL="file:./dev.db"
# Railway production should use Railway Postgres instead:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# Frontend → Backend
# Local Vite frontend:
CLIENT_ORIGIN=http://localhost:5173
# Railway client example:
# CLIENT_ORIGIN=https://your-brutus-client.up.railway.app

# Security
JWT_SECRET=replace-me-with-openssl-rand-base64-32
WALLET_AUTH_ENABLED=false

# BNB Testnet only while these contracts are testnet addresses
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
BRUTUS_COMBAT_REWARDS=0x22703D0153133450067C2A310D07d44f1Af7584a
# Set only in Railway variables / local server/.env. Never commit a real key.
# BRUTUS_OPERATOR_PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY
